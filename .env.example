# Copy this file to .env.local and fill in real values.
# See README.md → "Environment Variables" for setup details.

# --- NocoDB (backend data source) ---
# Account Settings → Tokens in NocoDB
NOCODB_API_TOKEN=
# Defaults to https://ndb.startmunich.de if unset
NOCODB_BASE_URL=https://ndb.startmunich.de
# Table IDs — visible in the NocoDB URL when the table is open
NOCODB_STARTUPS_TABLE_ID=
NOCODB_MEMBERS_TABLE_ID=
NOCODB_PARTNERS_TABLE_ID=
NOCODB_NEWS_TABLE_ID=
NOCODB_WAITLIST_TABLE_ID=

# --- Cloudflare Turnstile (waitlist captcha) ---
# Dashboard → Turnstile → your site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Luma (upcoming events feed) ---
# Luma → Calendar settings → API keys
LUMA_API_KEY=

# --- PostHog (analytics, optional) ---
# Project Settings → Project API Key. Omit to disable analytics in dev.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=

# --- Public site URL ---
# Used for absolute links, OG tags, etc. Vercel sets this automatically in
# production; set it for local dev only if you need absolute URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Internal API ---
STARTMUNICH_API_KEY=
